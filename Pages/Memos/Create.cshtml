@page
@model CrudApp.Pages_Memos.CreateModel

@{
    ViewData["Title"] = "新規登録";
}

<h1>新規登録</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="form-group">
                <label asp-for="Memo.Title"
                       class="control-label">
                </label>

                <input asp-for="Memo.Title"
                       class="form-control" />

                <span asp-validation-for="Memo.Title"
                      class="text-danger">
                </span>
            </div>

            <div class="form-group">

                <label asp-for="Memo.Description"></label>

                <textarea
                    asp-for="Memo.Description"
                    class="form-control"
                    rows="3">
                </textarea>

            </div>

            <div class="form-group">

                <label asp-for="Memo.DueDate"></label>

                <input
                asp-for="Memo.DueDate"
                type="datetime-local"
                class="form-control" />

            </div>

            <div class="form-group mt-3">

                <input type="submit"
                       value="保存"
                       class="btn btn-success" />

                <a asp-page="./Index"
                   class="btn btn-secondary">
                    前のページに戻る
                </a>

            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
